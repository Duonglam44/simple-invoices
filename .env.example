# 101 Digital sandbox configuration.
# Copy this file to `.env.local` and fill in the real values.
# NOTE: none of these are prefixed with NEXT_PUBLIC_ on purpose — they are
# only ever read on the server and must never reach the browser bundle.

# Identity server (OAuth2 token endpoint)
AUTH_BASE_URL=
AUTH_TOKEN_PATH=

# API gateway (membership-service / invoice-service)
API_BASE_URL=

# OAuth2 application credentials (server-side only, keep secret)
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret
